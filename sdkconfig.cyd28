# CYD 2.8" ILI9341 (ESP32) sdkconfig defaults
CONFIG_IDF_TARGET="esp32"

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Console — UART0
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# Main task stack
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# FreeRTOS tick rate
CONFIG_FREERTOS_HZ=1000

# mbedTLS — reduce peak RAM on 320 KB SRAM ESP32
# TLS 1.3 handshake_params struct is ~4.7 KB; TLS 1.2 is ~2 KB — disable 1.3
CONFIG_MBEDTLS_SSL_PROTO_TLS1_3=n
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=8192
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
# Drop peer cert after validation (saves ~1-2 KB during handshake)
CONFIG_MBEDTLS_SSL_KEEP_PEER_CERTIFICATE=n
