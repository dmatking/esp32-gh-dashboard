menu "Dashboard Configuration"

config GH_USERNAME
    string "GitHub username (compile-time fallback)"
    default ""
    help
        Optional. Normally set at runtime via the first-boot provisioning
        portal and stored in NVS. Only used if NVS is empty.

config GH_TOKEN
    string "GitHub personal access token (compile-time fallback)"
    default ""
    help
        Optional. Normally set at runtime via the first-boot provisioning
        portal and stored in NVS. Only used if NVS is empty.
        Needs repo scope. Traffic API requires auth.

config DASHBOARD_CYCLE_SEC
    int "Screen cycle interval (seconds)"
    default 30
    range 5 300

config DASHBOARD_TIMEZONE
    string "Timezone (POSIX TZ string)"
    default "CST6CDT,M3.2.0,M11.1.0"
    help
        POSIX TZ string for local time. Examples:
          CST6CDT,M3.2.0,M11.1.0   US Central (handles DST)
          EST5EDT,M3.2.0,M11.1.0   US Eastern
          MST7MDT,M3.2.0,M11.1.0   US Mountain
          PST8PDT,M3.2.0,M11.1.0   US Pacific
          UTC0                      UTC

config DASHBOARD_REFRESH_HOUR
    int "Daily refresh hour (local time, 0-23)"
    default 6
    range 0 23
    help
        Hour of day in local time at which stats are re-fetched from GitHub.
        GitHub traffic data typically updates around midnight UTC.

endmenu
