# CYD-S3 2.8" ILI9341 (ESP32-S3 + 8MB OPI PSRAM, 16MB Flash) sdkconfig defaults
CONFIG_IDF_TARGET="esp32s3"

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# PSRAM — 8MB OPI (octal SPI)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_TYPE_AUTO=y

# Console — no USB-UART IC on this board; Type-C uses USB_SERIAL_JTAG
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# CPU
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# Main task stack
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# FreeRTOS tick rate
CONFIG_FREERTOS_HZ=1000

# Custom 16MB partition table (CYD-S3 has 16MB flash)
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_cyd28s3.csv"

# Size optimization (plenty of room, but matches CYD pattern)
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
