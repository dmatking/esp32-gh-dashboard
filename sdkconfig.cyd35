# CYD 3.5" ST7796 (ESP32, 4MB Flash) sdkconfig defaults
CONFIG_IDF_TARGET="esp32"

# Flash
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Console — UART0
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# Main task stack
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# FreeRTOS tick rate
CONFIG_FREERTOS_HZ=1000

# mbedTLS — reduce peak RAM on 320 KB SRAM ESP32 (same trims as CYD 2.8")
CONFIG_MBEDTLS_SSL_PROTO_TLS1_3=n
CONFIG_MBEDTLS_DYNAMIC_BUFFER=y
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=8192
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=4096
CONFIG_MBEDTLS_SSL_KEEP_PEER_CERTIFICATE=n

# Custom 4MB partition table (same layout as CYD 2.8")
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_cyd.csv"

# Size optimization
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
